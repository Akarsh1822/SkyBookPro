<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Booking_Date_Must_Be_Future</fullName>
    <active>true</active>
    <errorConditionFormula>Flight__r.Departure_DateTime__c &lt;= NOW()</errorConditionFormula>
    <errorDisplayField>Flight__c</errorDisplayField>
    <errorMessage>Departure must be a future date. Please select a flight with a future departure.</errorMessage>
</ValidationRule>
